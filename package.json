{
  "name": "qq-farm-bot-ui-better",
  "private": true,
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "build": "turbo run build",
    "build:core": "turbo run build -F=core",
    "build:web": "turbo run build -F=web",
    "dev": "turbo run dev",
    "dev:core": "turbo run dev -F=core",
    "dev:web": "turbo run dev -F=web",
    "start": "turbo run start -F=core",
    "lint": "turbo run lint",
    "lint:web": "turbo run lint -F=web",
    "lint:core": "turbo run lint -F=core",
    "package:win": "pnpm build && turbo run build:win -F=core",
    "package:linux": "pnpm build && turbo run build:linux -F=core",
    "package:mac": "pnpm build && turbo run build:mac -F=core",
    "package:release": "pnpm build && turbo run build:release -F=core",
    "install:all": "pnpm install -r"
  },
  "devDependencies": {
    "turbo": "^2.8.12"
  }
}
